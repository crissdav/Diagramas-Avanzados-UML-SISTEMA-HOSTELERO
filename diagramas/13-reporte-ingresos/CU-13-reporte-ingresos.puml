@startuml CU-13-reporte-ingresos
' ============================================================
' DIAGRAMA DE SECUENCIA: Generar Reporte de Ingresos
' ============================================================
' CASO DE USO: CU-13 - Generar reportes de ingresos
' REQUISITOS FUNCIONALES: RF-08.1
' REGLAS DE NEGOCIO: -
' ============================================================

title Diagrama de Secuencia: CU-13 - Generar Reporte de Ingresos

actor "Administrador" as Admin
participant ":InterfazReportes" as IR
participant ":ControladorReportes" as CR
database ":BaseDatos" as BD

activate Admin

Admin -> IR: 1. generarReporteIngresos(periodo, fechas)
activate IR

IR -> CR: 2. procesarReporteIngresos(periodo, fechas)
activate CR

CR -> BD: 3. SELECT SUM(monto) FROM pagos WHERE fecha BETWEEN...
activate BD
BD --> CR: 4. ingresoTotal
deactivate BD

CR -> BD: 5. SELECT tipo, SUM(monto) FROM pagos JOIN estadias GROUP BY tipo
activate BD
BD --> CR: 6. ingresosPorTipo
deactivate BD
note right: Desglose por tipo de habitación

CR -> BD: 7. SELECT metodo, SUM(monto) FROM pagos GROUP BY metodo
activate BD
BD --> CR: 8. ingresosPorMetodo
deactivate BD
note right: Desglose por método de pago

CR -> BD: 9. SELECT AVG(monto) FROM pagos WHERE fecha BETWEEN...
activate BD
BD --> CR: 10. promedioDiario
deactivate BD

CR -> CR: 11. calcularMetricas()
note right: - Ingreso total\n- Desglose por tipo\n- Desglose por método\n- Promedio diario

CR --> IR: 12. reporteGenerado
deactivate CR

IR --> Admin: 13. mostrarReporte()
note right: Gráficos y tablas\ncon datos de ingresos

Admin -> IR: 14. exportarReporte(formato)
activate IR

IR -> CR: 15. exportar(formato, reporte)
activate CR
CR --> IR: 16. archivoExportado
deactivate CR

IR --> Admin: 17. descargarArchivo()
deactivate IR

deactivate Admin
@enduml