@startuml CU-04-Registrar-Huesped-Nacional
' ============================================================
' DIAGRAMA DE SECUENCIA: Registrar Huésped Nacional
' ============================================================
' CASO DE USO: CU-04 - Gestionar huéspedes
' REQUISITOS FUNCIONALES: RF-03 (Registrar Huésped Nacional)
' REGLAS DE NEGOCIO: RN-01, RN-02, RN-03, RN-17
' ============================================================

title Diagrama de Secuencia: CU-04 - Registrar Huésped Nacional

actor "Recepcionista" as R
participant ":InterfazHuespedes" as IH
participant ":ControladorHuespedes" as CH
database ":BaseDatos" as BD

activate R

R -> IH: 1. registrarHuesped(datos, "Nacional")
activate IH

IH -> CH: 2. guardarHuesped(datos, tipo)
activate CH

CH -> CH: 3. validarDNI(datos.dni)
note right: Formato DNI: 8 dígitos

alt dniValido
    CH -> CH: 4. validarCamposMINCETUR(datos)
    note right: RF-03.4: D.S.N.°005-2021-MINCETUR
    
    alt camposCompletos
        CH -> BD: 5. INSERT INTO huespedes (datos...)
        activate BD
        BD --> CH: 6. idHuesped
        deactivate BD
        
        alt menoresAcompanantes
            CH -> CH: 7. validarMenores(menores)
            note right: RN-04: Registro de menores
            loop por cada menor
                CH -> BD: 8. INSERT INTO menores (idHuesped, datos...)
                activate BD
                BD --> CH: 9. ok
                deactivate BD
            end
        end
        
        CH -> BD: 10. INSERT INTO auditoria (usuario, accion, detalle)
        activate BD
        BD --> CH: 11. ok
        deactivate BD
        
        CH --> IH: 12. exito(idHuesped)
        deactivate CH
        IH --> R: 13. confirmarRegistro()
    else camposIncompletos
        CH --> IH: 14. error("Campos MINCETUR incompletos")
        deactivate CH
        IH --> R: 15. mostrarError()
        note right: MSJ-03: "Faltan campos obligatorios"
    end
else dniInvalido
    CH --> IH: 16. error("DNI inválido")
    deactivate CH
    IH --> R: 17. mostrarError()
    note right: MSJ-01: "Documento no válido"
end

deactivate IH
deactivate R
@enduml